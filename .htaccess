# PharmaCore - Prevent WordPress from intercepting requests
# This .htaccess file takes precedence over the root WordPress .htaccess

<IfModule mod_rewrite.c>
    RewriteEngine On

    # L-1: Force HTTPS in production (comment out for local dev without SSL)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Allow direct access to all files and directories in this folder
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Don't rewrite requests, just serve the files as-is
    # This prevents WordPress from taking over
</IfModule>

# ── Security: Block access to sensitive files (C-2, L-2) ─────────────────────
<FilesMatch "^(\.env|config\.db\.php|install\.sh|pharmacy_npr\.sql|install\.lock|CONTEXT\.md|TASKS\.md|pharmacore-integration\.md|\.gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# ── Security Headers (L-2) ───────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Disable WordPress error handling from parent directory
<IfModule mod_php.c>
    php_flag engine on
</IfModule>
